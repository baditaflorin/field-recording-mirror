#!/usr/bin/env sh
# Conventional Commits prefix gate.
set -e
msg_file="$1"
first_line=$(head -n 1 "$msg_file")
pattern='^(feat|fix|chore|docs|refactor|test|ops|perf|style|build|ci|revert)(\([a-z0-9._-]+\))?!?: .+'
if ! printf '%s' "$first_line" | grep -Eq "$pattern"; then
  printf 'commit-msg: subject must start with a Conventional Commits prefix (feat:, fix:, chore:, docs:, refactor:, test:, ops:, perf:, style:, build:, ci:, revert:).\n' >&2
  printf 'got: %s\n' "$first_line" >&2
  exit 1
fi
