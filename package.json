{
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "tone": "^15.0.4"
  },
  "description": "A private browser instrument that records 30 seconds of now and replays it as a subtly altered sonic mirror.",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.2",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^9.1.2",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": "\u003e=22"
  },
  "homepage": "https://baditaflorin.github.io/field-recording-mirror/",
  "license": "MIT",
  "name": "field-recording-mirror",
  "overrides": {
    "protobufjs": "7.5.6"
  },
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/baditaflorin/field-recording-mirror.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "node scripts/prepare-pages-dir.mjs \u0026\u0026 tsc -b \u0026\u0026 vite build \u0026\u0026 node scripts/write-version.mjs \u0026\u0026 node scripts/copy-404.mjs \u0026\u0026 node scripts/check-pages-build.mjs",
    "preview": "vite preview",
    "pages-preview": "npm run build \u0026\u0026 node scripts/serve-static.mjs docs",
    "lint": "eslint . \u0026\u0026 prettier --check .",
    "fmt": "prettier --write .",
    "typecheck": "tsc -b --pretty",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "smoke": "bash scripts/smoke.sh",
    "audit": "npm audit --audit-level=high",
    "install-hooks": "husky",
    "prepare": "husky"
  },
  "type": "module",
  "version": "0.2.0"
}
